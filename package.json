{
  "name": "nexcom-turbo",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo watch dev --continue",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "db:push": "turbo -F @nexcom/db push",
    "db:studio": "turbo -F @nexcom/db studio"
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "^2.1.3",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.1.29",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "trustedDependencies": [
    "core-js-pure",
    "esbuild"
  ]
}
